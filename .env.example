# ─── Neon PostgreSQL (connection string from Neon dashboard) ─────────────────
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ─── Google Analytics (Measurement ID from GA4 dashboard) ────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Canonical site URL (set to your production domain) ──────────────────────
NEXT_PUBLIC_SITE_URL=https://contianer-tetris.adityadahake.dev

# ─── Microsoft Clarity (Project ID from clarity.microsoft.com/projects) ──────
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# ─── Vercel Analytics & Speed Insights ───────────────────────────────────────
# These are automatically detected by Vercel — no key needed.
# For local preview: npm i @vercel/analytics @vercel/speed-insights (already installed)
